# ============================================================================
# Production Environment Configuration
# ============================================================================
# Use this template for production deployments
# Ensure all sensitive values are properly set in your deployment platform

# ============================================================================
# GEMINI API (PRODUCTION)
# ============================================================================
# Set via Docker secrets or environment management system
GEMINI_API_KEY=${GEMINI_API_KEY}

GEMINI_MODEL=gemini-pro
GEMINI_MAX_TOKENS=2048
GEMINI_TEMPERATURE=0.7

# ============================================================================
# STREAMLIT CONFIGURATION (PRODUCTION)
# ============================================================================
# Use 0.0.0.0 for Docker containers
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# For reverse proxy setup with Nginx
STREAMLIT_SERVER_BASE_URL_PATH=/dashboard

# ============================================================================
# APPLICATION CONFIGURATION (PRODUCTION)
# ============================================================================
# Disable debug mode in production
DEBUG=false

# Maximum upload size (adjust based on your needs)
MAX_UPLOAD_SIZE_MB=50

# Data directory (use mounted volume in Docker)
DATA_DIR=/data

# ============================================================================
# WORDPRESS INTEGRATION
# ============================================================================
# Set your actual WordPress domain
WORDPRESS_DOMAIN=yourdomain.com

# Streamlit app domain
STREAMLIT_DOMAIN=app.yourdomain.com

# ============================================================================
# SECURITY (PRODUCTION)
# ============================================================================
# Set these for additional security
# ALLOWED_DOMAINS=yourdomain.com,app.yourdomain.com
# CORS_ORIGINS=https://yourdomain.com
# SESSION_TIMEOUT=3600
