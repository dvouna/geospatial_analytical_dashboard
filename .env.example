# ============================================================================
# Streamlit Data Visualization & AI Query Application
# Environment Variables Configuration
# ============================================================================
# Copy this file to .env and update with your actual values
# Never commit .env file with real secrets to version control!

# ============================================================================
# GEMINI API CONFIGURATION
# ============================================================================
# Get your Gemini API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model and parameters
GEMINI_MODEL=gemini-pro
GEMINI_MAX_TOKENS=2048
GEMINI_TEMPERATURE=0.7

# ============================================================================
# STREAMLIT CONFIGURATION
# ============================================================================
# Server port (default: 8501)
STREAMLIT_SERVER_PORT=8501

# Server address (localhost for development, 0.0.0.0 for Docker)
STREAMLIT_SERVER_ADDRESS=localhost

# Base URL path (for reverse proxy setups, e.g., /dashboard)
STREAMLIT_SERVER_BASE_URL_PATH=/

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
# Debug mode (true/false)
DEBUG=false

# Maximum upload file size in MB
MAX_UPLOAD_SIZE_MB=100

# Data directory path
DATA_DIR=data

# ============================================================================
# WORDPRESS INTEGRATION (PRODUCTION DEPLOYMENT)
# ============================================================================
# WordPress domain (for CORS and integration)
# WORDPRESS_DOMAIN=yourdomain.com

# Streamlit app domain (for SSL and reverse proxy)
# STREAMLIT_DOMAIN=app.yourdomain.com

# ============================================================================
# DATABASE (Optional - for future use)
# ============================================================================
# DATABASE_URL=
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=streamlit_app
# DATABASE_USER=
# DATABASE_PASSWORD=
