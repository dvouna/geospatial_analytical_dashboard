# ============================================================================
# FLC26 Geospatial Analytical Dashboard — VPS Production Environment Template
# ============================================================================
# Copy this file to /opt/geospatial-dashboard/.env on the VPS and populate
# the values. Do NOT commit a populated copy to version control.
#
# This file is tracked as a template (no real secrets). The .gitignore rule
# for .env.production was added during the security audit — remove that rule
# if you wish to continue tracking this template, or rename it to
# .env.production.example.
# ============================================================================

# ── Gemini API ────────────────────────────────────────────────────────────────
# Required for the AI Research Assistant page.
# Obtain from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_production_gemini_api_key_here

GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=2048
GEMINI_TEMPERATURE=0.7

# ── Streamlit server ──────────────────────────────────────────────────────────
# The container binds to 0.0.0.0:8501; Nginx reverse-proxies external traffic.
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# If serving at a sub-path (e.g. /dashboard), set this. Leave as / for root.
STREAMLIT_SERVER_BASE_URL_PATH=/

# ── Application ───────────────────────────────────────────────────────────────
# Keep DEBUG=false in production. Set to true only for troubleshooting —
# this will expose full Python stack traces in the browser UI.
DEBUG=false

MAX_UPLOAD_SIZE_MB=50

# Path to data directory inside the container (mapped via docker-compose volume)
DATA_DIR=/app/data

# ── Domain ────────────────────────────────────────────────────────────────────
SITE_DOMAIN=healthdashboard.afiuk.org
